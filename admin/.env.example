# ── Clerk ─────────────────────────────────────────────────
# Obtenir sur : https://dashboard.clerk.com → API Keys → Publishable key
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx

# ── URL Backend ───────────────────────────────────────────
# IMPORTANT : doit se terminer par /api
VITE_API_URL=http://localhost:5000/api

# ── Email Administrateur ──────────────────────────────────
# L'email exact de votre compte Clerk qui aura accès au dashboard complet.
# Les autres comptes seront considérés comme bailleurs (s'ils ont un clerkId lié).
# Si laissé vide → tout utilisateur connecté aura accès admin (développement uniquement).
VITE_ADMIN_EMAIL=votre.email@gmail.com
