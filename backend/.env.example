# ── Serveur ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ──────────────────────────────────────────────
# Obtenir sur : https://cloud.mongodb.com


# ── Clerk (Auth) ─────────────────────────────────────────
# Obtenir sur : https://dashboard.clerk.com
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxx

