# ── Clerk (Auth) ─────────────────────────────────────────
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx

# ── URL du Backend ────────────────────────────────────────
# ⚠️  IMPORTANT : sur téléphone physique, "localhost" ne fonctionne PAS.
# Tu dois utiliser l'adresse IP locale de ton PC sur le réseau WiFi.
#
# Comment trouver ton IP ?
#   Windows → ouvre un terminal → tape "ipconfig"
#             → cherche "Carte réseau sans fil Wi-Fi" → "Adresse IPv4"
#             → exemple : 192.168.1.4
#
# Exemple final :
EXPO_PUBLIC_API_URL=http://192.168.1.4:5000/api
#
# ⚠️  Ton téléphone ET ton PC doivent être connectés au même réseau WiFi.
# Après chaque modification de ce fichier → relancer avec : npx expo start --clear
