# ── Clerk (Auth) ─────────────────────────────────────────
# Obtenir sur : https://dashboard.clerk.com → API Keys
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx

# ── URL de ton backend ────────────────────────────────────
# En développement avec un simulateur Android → utilise 10.0.2.2 à la place de localhost
# En développement iOS → localhost fonctionne
EXPO_PUBLIC_API_URL=http://localhost:5000/api

# ── Sentry (optionnel) ────────────────────────────────────
# EXPO_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
